# GCSS Go backend (local/dev)
PORT=8080
# Comma-separated list of allowed browser origins, or '*' to allow any.
CORS_ORIGINS=http://localhost:3000,https://v3.gcss.hk,https://gcss.hk,https://www.gcss.hk
# Where to store incoming requests (JSON Lines)
DATA_FILE=data/requests.jsonl
# SQLite database path (primary storage)
DB_PATH=data/gcss.sqlite

# Encryption secret for user PII (PBKDF2 key derivation + AES-256-GCM)
# IMPORTANT: Change this in production and never expose it.
ENCRYPTION_SECRET=gcss-change-this-secret-in-production

# Auth (demo/dev)
# When true, /api/auth/password/request-reset will include a demoCode in the JSON response
# so you can test the reset flow without real email sending.
AUTH_RETURN_RESET_CODE=true

# CAPTCHA (optional)
# Set to one of: none | auto | turnstile | tencent
# - none: disable captcha checks (default)
# - auto: accept the provider specified by the client (still requires secrets)
# - turnstile: require Cloudflare Turnstile proof on login
# - tencent: require Tencent Captcha proof on login
CAPTCHA_PROVIDER=none

# Cloudflare Turnstile
TURNSTILE_SECRET_KEY=

# Tencent Captcha
TENCENT_CAPTCHA_APP_ID=
TENCENT_CAPTCHA_APP_SECRET_KEY=
